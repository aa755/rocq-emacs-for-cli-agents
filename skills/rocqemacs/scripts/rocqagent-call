#!/usr/bin/env python3
"""Serialize rocqagent emacsclient calls per server.

This wrapper prevents the common wedge where multiple shell-side emacsclient
requests are sent to the same rocqagent daemon at once. Use it for
coqcheck_until/coqquery_at_curpoint/save-file calls. If a long-running check is
already in flight, read the status file or run `rocqagent-health --skip-ping`
and use the cancel file instead of queueing another RPC.
"""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


REPO_DIR = Path(__file__).resolve().parent
HEALTH = REPO_DIR / "rocqagent-health"


def server_tag(server: str) -> str:
    return "".join(ch if (ch.isalnum() or ch in "_.-") else "_" for ch in server)


def control_dir() -> Path:
    return Path(os.environ.get("TMPDIR", "/tmp")) / "rocqagent"


def lock_path(server: str) -> Path:
    return control_dir() / f"{server_tag(server)}.rpc.lock"


def run_health(server: str, *, skip_ping: bool) -> dict:
    cmd = [str(HEALTH)]
    if skip_ping:
        cmd.append("--skip-ping")
    cmd.append(server)
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if proc.returncode not in (0, 1):
        raise RuntimeError(proc.stderr.strip() or proc.stdout.strip() or "rocqagent-health failed")
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"could not parse rocqagent-health output: {exc}") from exc


def active_emacsclient_pids(server: str) -> list[int]:
    proc = subprocess.run(["ps", "-eo", "pid=,args="], capture_output=True, text=True, check=True)
    pids: list[int] = []
    for line in proc.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        pid_text, _, args_text = line.partition(" ")
        try:
            pid = int(pid_text)
        except ValueError:
            continue
        if pid == os.getpid():
            continue
        try:
            argv = shlex.split(args_text)
        except ValueError:
            continue
        if not argv:
            continue
        exe = os.path.basename(argv[0])
        if exe != "emacsclient":
            continue
        if "-s" not in argv:
            continue
        try:
            idx = argv.index("-s")
            target = argv[idx + 1]
        except (ValueError, IndexError):
            continue
        if target == server:
            pids.append(pid)
    return pids


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("server", help="Emacs server / socket name")
    parser.add_argument("expr", help="Elisp expression to pass to emacsclient --eval")
    parser.add_argument("--wait-lock", action="store_true",
                        help="Wait for another rocqagent-call lock holder instead of failing fast")
    parser.add_argument("--skip-ping", action="store_true",
                        help="Skip the idle-server responsiveness ping before sending the RPC")
    args = parser.parse_args(argv)

    control_dir().mkdir(parents=True, exist_ok=True)
    lockfile = lock_path(args.server)
    with open(lockfile, "a+", encoding="utf-8") as lock:
        try:
            fcntl.flock(lock.fileno(), fcntl.LOCK_EX | (0 if args.wait_lock else fcntl.LOCK_NB))
        except BlockingIOError:
            print(
                f"rocqagent-call: another rocqagent request is already in flight for {args.server}; "
                "wait for it to finish or cancel it via the status file",
                file=sys.stderr,
            )
            return 73

        health = run_health(args.server, skip_ping=True)
        health_state = health.get("health")

        if health_state in {
            "stale_dead_pid_busy",
            "stale_dead_pid_idle",
            "stale_dead_socket_busy",
            "stale_dead_socket_idle",
            "no_status_dead_socket",
        }:
            print(
                f"rocqagent-call: server {args.server} is not live ({health_state}); "
                "inspect rocqagent-health output and clean up the stale server/status first",
                file=sys.stderr,
            )
            return 77

        if health.get("busy") is True:
            print(
                f"rocqagent-call: server {args.server} is busy with {health.get('kind')} id={health.get('id')} "
                f"for {health.get('file')}; use the status file / cancel-file instead of queueing another RPC",
                file=sys.stderr,
            )
            return 74

        other_clients = active_emacsclient_pids(args.server)
        if other_clients:
            print(
                f"rocqagent-call: found existing emacsclient process(es) for {args.server}: "
                + ", ".join(str(pid) for pid in other_clients),
                file=sys.stderr,
            )
            return 75

        if args.skip_ping:
            if health_state not in {"idle_no_ping", "busy_no_ping"} and health_state != "no_status_no_ping":
                print(
                    f"rocqagent-call: server {args.server} is not safely callable "
                    f"without a ping ({health_state}); run without --skip-ping",
                    file=sys.stderr,
                )
                return 76
        else:
            ping = run_health(args.server, skip_ping=False)
            if ping.get("health") not in {"idle_live", "live_no_status"}:
                print(
                    f"rocqagent-call: server {args.server} is not safely callable "
                    f"({ping.get('health')}); inspect health/status before sending another RPC",
                    file=sys.stderr,
                )
                return 76

        proc = subprocess.run(
            ["emacsclient", "-s", args.server, "--eval", args.expr],
            text=True,
            check=False,
        )
        return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
