#!/usr/bin/env python3
"""Codex hook that blocks direct dune invocations in Rocq workspaces."""

from __future__ import annotations

import json
import shlex
import sys
from pathlib import Path


ERROR = (
    "dune is not allowed in this project. use emacs for interactive editing "
    "of .v files as that does incremental checks. see the rocqemacs skill. "
    "to ensure all proofs in this repo build, just interactively check all.v "
    "till the end."
)


def command_tokens(command: str) -> list[str]:
    try:
        lexer = shlex.shlex(command, posix=True, punctuation_chars=";&|()")
        lexer.whitespace_split = True
        return list(lexer)
    except ValueError:
        return (
            command.replace(";", " ")
            .replace("|", " ")
            .replace("&", " ")
            .replace("(", " ")
            .replace(")", " ")
            .split()
        )


def main() -> int:
    try:
        payload = json.load(sys.stdin)
    except json.JSONDecodeError:
        return 0

    tool_input = payload.get("tool_input") or {}
    command = ""
    if isinstance(tool_input, dict):
        command = tool_input.get("command") or tool_input.get("cmd") or ""
    if not isinstance(command, str):
        return 0

    if any(Path(token).name == "dune" for token in command_tokens(command)):
        print(ERROR, file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
